{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Stage 1: minimal_rrt (GUI, stage 1)",
      "type": "debugpy",
      "request": "launch",
      "module": "husky_assembly_tamp.motion_planner.stage1.minimal_rrt",
      "cwd": "${workspaceFolder}",
      "args": [
        "--stage",
        "1",
        "--position-res",
        "0.1",
        "--rotation-res",
        "0.2",
        "--max-time",
        "30",
        "--max-iterations",
        "2000",
        "--max-attempts",
        "5"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Stage 1: minimal_rrt (Headless, stage 1)",
      "type": "debugpy",
      "request": "launch",
      "module": "husky_assembly_tamp.motion_planner.stage1.minimal_rrt",
      "cwd": "${workspaceFolder}",
      "args": [
        "--stage",
        "1",
        "--no-gui",
        "--position-res",
        "0.1",
        "--rotation-res",
        "0.2",
        "--max-time",
        "30",
        "--max-iterations",
        "2000",
        "--max-attempts",
        "5"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
