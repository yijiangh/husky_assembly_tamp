        "--stage",
        "2",
        "--position-res",
        "0.1",
        "--rotation-res",
        "0.2",
        "--endpoint-ik-attempts",
        "20",
        "--max-time",
        "30",
        "--max-iterations",
        "2000",
        "--max-attempts",
        "5"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
