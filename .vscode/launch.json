    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Export PDDL from MT",
            "type": "python",
            "request": "launch",
            "program": "./scripts/pddl_experiments/parse_symbolic.py",
            "args": [
                "--planning_cases",
                "1",
                "--mt_file_name",
                // "box_MT_contact.json",
                // "one_tet_MT_layer_0_contact.json",
                // "tower_integral_one_len_MT_layer_0.json",
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Plan Symbolic Planner Case 1",
            "type": "python",
            "request": "launch",
            "program": "./scripts/pddl_experiments/plan_pddl.py",
            "args": [
                "--planning_cases",
                "1",
                "--mt_file_names",
                "one_tet_MT_layer_0_contact.json",
                // "tower_integral_one_len_MT_layer_0.json",
                // "box_MT_contact.json",
                "--symbolic_planner",
                "fd",
                // "pyplanners",
                "--output_to_file",
                "--output_to_console",
                // "--debug",
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Visualize plan",
            "type": "python",
            "request": "launch",
            "program": "./scripts/pddl_experiments/visualize_plan.py",
            "args": [
                "--planning_case",
                "1",
                "--mt_file_name",
                // "one_tet_MT_layer_0_contact",
                // "tower_integral_one_len_MT_layer_0",
                "box_MT_contact.json",
                "--symbolic_planner",
                "fd",
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
    ]
}