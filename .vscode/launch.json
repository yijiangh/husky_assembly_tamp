            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "M2-single bar grasp",
            "type": "python",
            "request": "launch",
            "program": "./scripts/milestone2/single_bar_grasp.py",
            "console": "integratedTerminal",
